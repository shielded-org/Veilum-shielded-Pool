# Copy to .env and fill in values:
#   cp .env.example .env

# Network: futurenet | testnet | local
STELLAR_NETWORK=testnet

# Deployer / admin / relayer gas sponsor (bevis)
SOURCE_ACCOUNT=bevis
STELLAR_SECRET_KEY=
STELLAR_PUBLIC_KEY=

# End-user Stellar account (deposits only — private transfer goes via relayer)
USER_ACCOUNT=kenzmans
USER_SECRET_KEY=

# Private transfer recipient (ZK identity: deterministic "taiwo" note keys)
RECIPIENT_ACCOUNT=taiwo
RECIPIENT_SECRET_KEY=

# Relayer HTTP endpoint (signer config lives in services/relayer/.env)
RELAYER_URL=http://127.0.0.1:8787

# Reuse UltraHonk verifier from scripts/deployment.json
SKIP_VERIFIER_DEPLOY=1

# Skip all contract deploys (reuse scripts/deployment.json)
SKIP_DEPLOY=0

# Do not call friendbot for bevis / kenzmans / taiwo when already funded
SKIP_FUND=1
SKIP_USER_FUND=0
SKIP_RECIPIENT_FUND=0

# Deterministic ZK note keys (owner, taiwo, …)
KEY_DERIVATION_SEED=stellar-shielded-deterministic-seed-v1
