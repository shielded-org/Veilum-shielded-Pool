# Copy to .env.local for local dev.
# Production uses same-origin /api/relayer and /api/asp (Vercel rewrites) — no env vars required for URLs.
# Local dev: Vite proxies /api/* to these targets (or defaults to localhost).

VITE_RELAYER_URL=http://127.0.0.1:8787
VITE_ASP_URL=http://127.0.0.1:8788
VITE_ASP_ADMIN_TOKEN=
