# Copy to .env.local for local dev.
# Production uses same-origin /api/* (Vercel rewrites) — no env vars required there.
#
# Local dev: the browser calls /api/relayer, /api/asp, /api/indexer.
# Vite proxies those paths to the URLs below (loadEnv in vite.config.ts).

# Production backends (default in .env.local):


# Local services instead (uncomment to run relayer/asp/indexer locally):
# VITE_RELAYER_URL=http://127.0.0.1:8787
# VITE_ASP_URL=http://127.0.0.1:8788
# VITE_INDEXER_URL=http://127.0.0.1:8789

VITE_ASP_ADMIN_TOKEN=
