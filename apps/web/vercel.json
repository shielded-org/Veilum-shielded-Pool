{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "installCommand": "cd ../.. && yarn install --frozen-lockfile",
  "buildCommand": "cd ../.. && yarn workspace @stellar-shielded/web build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/api/relayer/:path*",
      "destination": "https://veilum-shielded-pool-1.onrender.com/:path*"
    },
    {
      "source": "/api/asp/:path*",
      "destination": "https://veilum-shielded-pool.onrender.com/:path*"
    },
    {
      "source": "/api/indexer/:path*",
      "destination": "https://veilum-shielded-indexer.fly.dev/:path*"
    },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
