# Relayer config — copy to .env:
#   cp .env.example .env

STELLAR_NETWORK=testnet

# Stellar CLI identity that pays fees and submits shielded_transfer_routed
RELAYER_SOURCE_ACCOUNT=bevis
RELAYER_SECRET_KEY=

# Optional public-key sanity check
RELAYER_PUBLIC_KEY=

# Soroban RPC (defaults match privacy/packages/config/networks.json testnet)
STELLAR_RPC_URL=https://soroban-testnet.stellar.org:443
STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015

RELAYER_PORT=8787
RELAYER_HOST=0.0.0.0
RELAYER_CONFIRM_TIMEOUT_MS=180000
RELAYER_CONFIRM_POLL_MS=2000
